# Soneium Minato testnet
SONEIUM_MINATO_RPC_URL=https://rpc.minato.soneium.org/
DEPLOYER_PRIVATE_KEY=

# Deployed contract address, filled after npm run deploy:minato
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CONTRACT_DEPLOY_BLOCK=

# WalletConnect project id for RainbowKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional display override. Defaults to /nft-placeholder.svg in development.
NEXT_PUBLIC_NFT_IMAGE_URL=

# Pinata
PINATA_JWT=
PINATA_GATEWAY=example-gateway.mypinata.cloud

# NFT metadata inputs
NFT_NAME=Community Attendance Proof
NFT_SYMBOL=CAP
NFT_DESCRIPTION=Participation proof for the community event on Soneium Minato.
NFT_IMAGE_CID=
NFT_EXTERNAL_URL=
NFT_METADATA_URI=

# Optional Blockscout verification key. Blockscout often accepts a placeholder.
BLOCKSCOUT_API_KEY=
